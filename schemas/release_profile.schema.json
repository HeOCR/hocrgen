{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heocr.github.io/hocrgen/schemas/release_profile.schema.json",
  "title": "hocrgen release profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "description",
    "include_sources",
    "exclude_sources",
    "allowed_rights_classifications",
    "synthetic_fraction_max",
    "privacy_mode",
    "publish_targets",
    "split_policy"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
    "description": { "type": "string" },
    "include_sources": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "exclude_sources": {
      "type": "array",
      "items": { "type": "string" }
    },
    "allowed_rights_classifications": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "open",
          "open_with_attribution",
          "sharealike",
          "restricted_review_only",
          "blocked"
        ]
      }
    },
    "allow_unknown_rights": {
      "type": "boolean"
    },
    "require_public_release_licenses": {
      "type": "boolean"
    },
    "synthetic_fraction_max": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "privacy_mode": {
      "enum": ["conservative", "review", "off"]
    },
    "publish_targets": {
      "type": "array",
      "items": {
        "enum": ["huggingface", "github_dataset_repo"]
      }
    },
    "split_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["train", "validation", "test"],
      "properties": {
        "train": { "type": "number", "minimum": 0, "maximum": 1 },
        "validation": { "type": "number", "minimum": 0, "maximum": 1 },
        "test": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
