{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heocr.github.io/hocrgen/schemas/source.schema.json",
  "title": "hocrgen source registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "sources"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "fetcher",
          "status",
          "default_public_release",
          "allowed_content_types",
          "rights_strategy",
          "normalized_license",
          "rights_classification",
          "requires_manual_review"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "name": { "type": "string" },
          "fetcher": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "status": { "enum": ["allowed", "review_only", "blocked"] },
          "default_public_release": { "type": "boolean" },
          "allowed_content_types": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "rights_strategy": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "values"],
            "properties": {
              "type": { "enum": ["exact_match", "contains", "manual_review"] },
              "values": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "normalized_license": { "type": "string" },
          "rights_classification": {
            "enum": [
              "open",
              "open_with_attribution",
              "sharealike",
              "restricted_review_only",
              "blocked"
            ]
          },
          "requires_manual_review": { "type": "boolean" },
          "settings": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "seed_manifest": { "type": "string" },
              "records_path": { "type": "string" },
              "synthetic_batch_size": { "type": "integer", "minimum": 1 },
              "synthetic_seed": { "type": "integer" },
              "template_ids": {
                "type": "array",
                "items": { "type": "string" }
              },
              "font_manifest": { "type": "string" },
              "text_corpus_path": { "type": "string" },
              "extra": { "type": "object" }
            }
          }
        }
      }
    }
  }
}
